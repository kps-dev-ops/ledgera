# Modèle de configuration — À COPIER en `.env` (qui est gitignoré).
# ⚠️ Ce fichier est suivi par git : n'y mettez JAMAIS de secret réel, uniquement
# des valeurs d'exemple.

# ---------------------------------------------------------------------------
# Commun
# ---------------------------------------------------------------------------
# Générer avec : python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=changez-moi-generez-une-cle-aleatoire

DB_NAME=ledgera
DB_USER=ledgera
DB_PASSWORD=changez-moi
DB_HOST=localhost
DB_PORT=5432
DATABASE_URL=postgres://ledgera:changez-moi@localhost:5432/ledgera

REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# Développement local (DJANGO_SETTINGS_MODULE=config.settings.dev via manage.py)
# ---------------------------------------------------------------------------
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ---------------------------------------------------------------------------
# Preprod / production (DJANGO_SETTINGS_MODULE=config.settings.prod)
# À renseigner dans les variables d'environnement Coolify, PAS dans un fichier
# versionné. Un seul domaine : le tenant est choisi par l'utilisateur connecté.
# ---------------------------------------------------------------------------
# ALLOWED_HOSTS=ledgera.ubbfy.com
# DEBUG est ignoré en prod (toujours False).

# Redirection HTTPS par Django. Laissez True sauf si Traefik s'en charge déjà et
# que les sondes de santé internes tapent en HTTP.
# SECURE_SSL_REDIRECT=True

# HSTS : 0 = désactivé (défaut, recommandé en preprod). Une fois activé, les
# navigateurs refusent le HTTP sur ce domaine pendant toute la durée annoncée —
# irréversible côté client. À passer à 31536000 (1 an) seulement en prod stabilisée.
# SECURE_HSTS_SECONDS=0

# SMTP — OBLIGATOIRE : allauth exige la vérification de l'adresse email, sans
# quoi aucun utilisateur ne peut finaliser sa connexion.
# Port 465 = SSL implicite -> EMAIL_USE_SSL=true et EMAIL_USE_TLS=false
# Port 587 = STARTTLS      -> EMAIL_USE_TLS=true et EMAIL_USE_SSL=false
# EMAIL_HOST=mail.exemple.com
# EMAIL_PORT=465
# EMAIL_USE_SSL=true
# EMAIL_USE_TLS=false
# EMAIL_HOST_USER=no-reply@exemple.com
# EMAIL_HOST_PASSWORD=changez-moi
# DEFAULT_FROM_EMAIL=no-reply@exemple.com

# GUNICORN_WORKERS=3
# LOG_LEVEL=INFO
